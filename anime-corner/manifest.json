{
  "id": "anime-corner",
  "name": "Anime Corner",
  "version": "1.5.3",
  "minNoctaliaVersion": "4.1.2",
  "author": "OpenAI",
  "license": "MIT",
  "repository": "https://github.com/tmokenc/vibed-noctalia-plugin",
  "description": "Anime art, wallpapers, and OP/ED theme browser for Noctalia",
  "tags": [
    "Bar",
    "Panel",
    "Anime",
    "Wallpaper",
    "Network"
  ],
  "entryPoints": {
    "main": "Main.qml",
    "barWidget": "BarWidget.qml",
    "panel": "Panel.qml",
    "settings": "Settings.qml"
  },
  "dependencies": {
    "plugins": []
  },
  "metadata": {
    "defaultSettings": {
      "panelDetached": true,
      "panelPosition": "left",
      "panelHeightRatio": 0.85,
      "panelWidth": 920,
      "attachmentStyle": "connected",
      "scale": 1,
      "booru": {
        "provider": "yandere",
        "safeOnly": true,
        "pageSize": 20,
        "randomOrder": false,
        "saveDirectory": "",
        "wallpaperCommand": "qs -c noctalia-shell ipc call wallpaper set {file} \"\"",
        "imagesPerRow": 3,
        "recentSearchTagLimit": 20,
        "danbooruTagIndexRefreshDays": 7,
        "variableCardSize": true
      },
      "animethemes": {
        "pageSize": 12,
        "recentSearchLimit": 20,
        "mpvCommand": "mpv"
      }
    }
  }
}
